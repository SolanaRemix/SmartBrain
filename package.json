{
  "name": "smartbrain-bots",
  "version": "1.0.0",
  "description": "AI/ML Engine and Stripe-powered plugin bots for smart contract deployment and auditing",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "deploy-bot": "node bots/SmartContractDeploy/index.js",
    "audit-bot": "node bots/SmartContractAudit/index.js",
    "test": "jest tests/",
    "test:unit": "jest tests/",
    "test:integration": "echo \"Integration tests not yet implemented\" && exit 0",
    "test:coverage": "jest tests/ --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,yml,yaml}\"",
    "build": "echo \"No build step required\" && exit 0",
    "validate:models": "bash -c 'for dir in models/*/; do [ -f \"$dir/metadata.json\" ] && ./scripts/validate-model.sh \"$dir\" || true; done'",
    "validate:datasets": "node datasets/validation/validate.js",
    "bootstrap": "./scripts/bootstrap.sh",
    "audit:security": "./scripts/audit.sh",
    "inference": "node inference/cli/index.js",
    "train": "node training/cli/index.js",
    "docs:scan": "node src/docs-engine/auto-updater.js --scan",
    "docs:update": "node src/docs-engine/auto-updater.js --update",
    "smart:analyze": "node src/smart-functions/auto-analyze.js",
    "brain:status": "node src/orval-db/index.js --status",
    "audit:node": "node src/node-audit/index.js"
  },
  "keywords": [
    "stripe",
    "smart-contracts",
    "blockchain",
    "bot",
    "automation",
    "ai",
    "ml",
    "machine-learning",
    "inference",
    "training"
  ],
  "author": "SmartBrain Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/SolanaRemix/SmartBrain.git"
  },
  "bugs": {
    "url": "https://github.com/SolanaRemix/SmartBrain/issues"
  },
  "homepage": "https://github.com/SolanaRemix/SmartBrain#readme",
  "dependencies": {
    "axios": "^1.6.2",
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "stripe": "^14.10.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^18.4.4",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "semantic-release": "^22.0.12"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
